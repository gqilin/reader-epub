{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "xml-ebook": ["../../src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite-env.d.ts"]
}
